-- Trash Lib Definition
local TrashLib = {}

function TrashLib:CreateWindow(titleText)
    -- Main Screen Gui
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "TrashLib_Gui"
    ScreenGui.Parent = game:GetService("CoreGui") or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    ScreenGui.ResetOnSpawn = false

    -- Main Window Frame
    local Window = Instance.new("Frame")
    Window.Name = "MainWindow"
    Window.Size = UDim2.new(0, 300, 0, 200)
    Window.Position = UDim2.new(0.4, 0, 0.4, 0)
    Window.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Window.BorderSizePixel = 2
    Window.BorderColor3 = Color3.fromRGB(50, 50, 50)
    Window.Active = true
    Window.Draggable = true 
    Window.ClipsDescendants = true -- Prevents content bleeding out during scaling animations
    Window.Parent = ScreenGui

    -- Title Bar
    local Title = Instance.new("TextLabel")
    Title.Name = "TitleBar"
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Title.Text = titleText or "Trash Lib"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextSize = 16
    Title.Font = Enum.Font.SourceSansBold
    Title.Parent = Window

    -- Container for UI Elements
    local Container = Instance.new("ScrollingFrame")
    Container.Name = "Container"
    Container.Size = UDim2.new(1, -10, 1, -40)
    Container.Position = UDim2.new(0, 5, 0, 35)
    Container.BackgroundTransparency = 1
    Container.CanvasSize = UDim2.new(0, 0, 0, 0)
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Container.ScrollBarThickness = 6 
    Container.Parent = Window

    -- Automatic Layout for Buttons
    local UIListLayout = Instance.new("UIListLayout")
    UIListLayout.Padding = UDim.new(0, 5)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Parent = Container

    -- ANIMATED TOGGLE BUTTON (Replaces old resize corner)
    local ToggleButton = Instance.new("TextButton")
    ToggleButton.Name = "MobileToggleButton"
    ToggleButton.Size = UDim2.new(0, 20, 0, 20)
    ToggleButton.Position = UDim2.new(1, -25, 1, -25)
    ToggleButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    ToggleButton.BorderSizePixel = 1
    ToggleButton.BorderColor3 = Color3.fromRGB(80, 80, 80)
    ToggleButton.Font = Enum.Font.SourceSansBold
    ToggleButton.Text = "^"
    ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleButton.TextSize = 14
    ToggleButton.ZIndex = 10
    ToggleButton.Parent = Window

    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 4)
    UICorner.Parent = ToggleButton

    -- Animation States & Logic
    local TweenService = game:GetService("TweenService")
    local isMinimized = false
    
    -- Save original window layout states
    local originalSize = Window.Size
    local originalPosition = Window.Position

    ToggleButton.MouseButton1Click:Connect(function()
        local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        
        if not isMinimized then
            -- Save current size/position immediately prior to running the shrink transition
            originalSize = Window.Size
            originalPosition = Window.Position
            isMinimized = true
            
            -- Turn off dragging so layout does not snap unexpectedly mid-animation
            Window.Draggable = false
            Container.Visible = false
            Title.Visible = false
            
            -- Animate entire Window to an ultra-wide top bar strip
            local windowTween = TweenService:Create(Window, tweenInfo, {
                Size = UDim2.new(0, 260, 0, 35),
                Position = UDim2.new(0.5, -130, 0, 10), -- Centers neatly at the top of device screen
                BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            })
            
            -- Make the button fill out across the structural layout width
            local buttonTween = TweenService:Create(ToggleButton, tweenInfo, {
                Size = UDim2.new(1, -10, 1, -10),
                Position = UDim2.new(0, 5, 0, 5),
                Text = "OPEN MENU"
            })
            
            windowTween:Play()
            buttonTween:Play()
        else
            isMinimized = false
            
            -- Restore the complete Window properties smoothly
            local windowTween = TweenService:Create(Window, tweenInfo, {
                Size = originalSize,
                Position = originalPosition,
                BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            })
            
            -- Return button safely back into its bottom corner placeholder 
            local buttonTween = TweenService:Create(ToggleButton, tweenInfo, {
                Size = UDim2.new(0, 20, 0, 20),
                Position = UDim2.new(1, -25, 1, -25),
                Text = "^"
            })
            
            windowTween:Play()
            buttonTween:Play()
            
            windowTween.Completed:Connect(function()
                if not isMinimized then
                    Container.Visible = true
                    Title.Visible = true
                    Window.Draggable = true -- Re-enables touch dragging functions safely
                end
            end)
        end
    end)

    -- Define elements inside the window object
    local WindowElements = {}

    -- Function to Create a Button
    function WindowElements:CreateButton(buttonText, callback)
        local Button = Instance.new("TextButton")
        Button.Name = buttonText.."_Btn"
        Button.Size = UDim2.new(1, -12, 0, 30)
        Button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        Button.TextColor3 = Color3.fromRGB(255, 255, 255)
        Button.Text = buttonText
        Button.Font = Enum.Font.SourceSans
        Button.TextSize = 14
        Button.BorderSizePixel = 0
        Button.Parent = Container

        Button.MouseButton1Click:Connect(function()
            pcall(callback)
        end)

        Container.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
        return Button
    end

    return WindowElements
end

return TrashLib
